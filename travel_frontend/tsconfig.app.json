{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue", "openapi.config.js"],
  "exclude": [
    "src/**/__tests__/*",
    "src/pages/DashboardPage.vue",
    "src/pages/admin/**/*",
    "src/pages/merchant/**/*",
    "src/pages/MessageWall*.vue",
    "src/composables/useMessageWall.ts",
    "src/pages/user/ShopPage.vue",
    "src/pages/user/ShopListPage.vue",
    "src/pages/user/OrderListPage.vue",
    "src/pages/user/OrderDetailPage.vue",
    "src/pages/user/CartPage.vue",
    "src/pages/user/ProductDetailPage.vue",
    "src/pages/user/CheckoutPage.vue"
  ],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
